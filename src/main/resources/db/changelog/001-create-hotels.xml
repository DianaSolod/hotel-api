<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
            http://www.liquibase.org/xml/ns/dbchangelog
            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="1" author="diana">

        <createTable tableName="hotels">

            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>

            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="description" type="VARCHAR(5000)"/>

            <column name="brand" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="house_number" type="INTEGER"/>

            <column name="street" type="VARCHAR(255)"/>

            <column name="city" type="VARCHAR(255)"/>

            <column name="country" type="VARCHAR(255)"/>

            <column name="post_code" type="VARCHAR(50)"/>

            <column name="phone" type="VARCHAR(100)"/>

            <column name="email" type="VARCHAR(255)"/>

            <column name="check_in" type="TIME"/>

            <column name="check_out" type="TIME"/>

        </createTable>

    </changeSet>

    <changeSet id="2" author="diana">

        <createTable tableName="hotel_amenities">

            <column name="hotel_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="amenity" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

        </createTable>

    </changeSet>

</databaseChangeLog>